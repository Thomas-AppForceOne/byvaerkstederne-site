# OS
.DS_Store
Thumbs.db

# Design files
Stitch-designs

# Grav cache & compiled
config/www/cache/
config/www/logs/
config/www/tmp/
config/www/backup/
config/www/assets/

# Grav vendor (installed at container runtime)
config/www/vendor/
config/www/bin/

# Migration runner vendor (installed via `composer install` in
# migrations/; reproducible from migrations/composer.lock)
migrations/vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Docker volumes (runtime data)
config/log/
config/keys/
config/crontabs/
config/custom-cont-init.d/
config/custom-services.d/

# Local env overrides
.env.local
.env.deploy

# Deploy staging and cached downloads
deploy/staging/
deploy/*.zip

# Auto-generated build-number markers — written by deploy/deploy.sh
# from `git rev-list --count HEAD` and shipped in the deploy package,
# never committed (they're a function of the commit, so committing
# would be a chicken-and-egg loop). See specifications/semantic_versioning_specification.md.
apex/BUILD
config/www/BUILD

# Backups (stored locally, not in git)
backups/

# Restore-to-scratch staging directories — never committed; contain
# decrypted PII and bug-report screenshots. The script paths
# operators choose at invocation (`restore.sh --to <dir>`,
# `RESTORE_LOCAL_TIER_DIR=<dir>`) vary, so we can't pre-list them
# here. The two below are kept as defensive cover in case an
# operator manually creates them — the scripts themselves never
# write to those exact paths.
deploy/staging-stage/
deploy/prod-stage/

# Restore-operation logs (per-tier, per-timestamp).
logs/restore-*.log

# User accounts (all excluded — use 'make create-admin' to bootstrap)
config/www/user/accounts/*
!config/www/user/accounts/.gitkeep

# Flex Objects indexes (auto-generated)
config/www/user/data/flex/indexes/

# Scheduler data (runtime)
config/www/user/data/scheduler/

# Notifications (runtime)
config/www/user/data/notifications/

# Remember-me tokens (runtime auth state)
config/www/user/data/rememberme/

# Feed cache
config/www/user/data/feed/

# Claude Code — ignore by default, but track project-level settings + hooks.
# Local per-operator state (permissions, worktree registry, transient
# scratch files) stays ignored via the patterns below.
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json
.claude/launch.json
.claude/worktrees/

# Node / Playwright
node_modules/
playwright-report/
test-results/
.env.test

# Adev workspace (local AI tooling state — not project artefacts)
.adev-workspace/

# GAN harness runtime state (regenerated each run — not project artefacts)
.gan/
.gan-state/
.gan-cache/

# Per-tier security.yaml — auto-generated by Grav at first request with a
# tier-specific salt. These belong to each runtime tier (dev/test/staging
# /prod), not to the repo. Committing local-tier salts would pin them as
# production values on the next deploy.
config/www/user/env/*/config/security.yaml

# review-and-plan / execute-fix-plan run artifacts (per-diff scratch — not
# project artefacts; regenerated each run).
.review-runs/

# spec-review-and-plan / spec-execute-fix-plan run artifacts (transient).
.spec-review-runs/

# promote-to-prod operator journal — operator-local audit trail, may carry
# sensitive --reason context. Kept on the operator's machine, never committed.
deploy/promotion-log.jsonl
