{% set h = page.header %}
<section style="position: relative; min-height: 90vh; display: flex; align-items: stretch; overflow: hidden; background: var(--surface-container-low);">
    <div style="width: 50%; padding: var(--space-20); display: flex; flex-direction: column; justify-content: center; z-index: 10; background: rgba(249,249,249,0.9); backdrop-filter: blur(8px);">
        <span class="bv-label" style="color: var(--secondary); letter-spacing: 0.2em; margin-bottom: var(--space-4);">{{ h.label|default('Vores Fælles Fristed') }}</span>
        <h1 class="bv-display" style="font-size: clamp(3rem, 8vw, 6rem); margin-bottom: var(--space-8);">{{ h.hero_heading|default('Kulturhus') }}</h1>
        <p class="bv-body-lg" style="max-width: 32rem; margin-bottom: var(--space-12);">{{ h.subtitle }}</p>
        <div style="display: flex; flex-wrap: wrap; gap: var(--space-4);">
            {% for button in h.buttons|feature_visible %}
            <a href="{{ button.url|default('#') }}" class="bv-btn bv-btn--{{ button.style|default('secondary') }}">{{ button.text }}</a>
            {% endfor %}
        </div>
    </div>
    <div style="position: absolute; right: 0; top: 0; width: 60%; height: 100%; z-index: 0;">
        {% if h.bg_image_url %}
        <img src="{{ h.bg_image_url }}" alt="{{ h.hero_heading }}" style="width: 100%; height: 100%; object-fit: cover;"/>
        {% endif %}
    </div>
</section>
