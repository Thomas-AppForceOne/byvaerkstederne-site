{% set h = page.header %}
{% set has_sidebar = h.wishlist or h.gallery_image %}
<section>
    <div class="bv-container">
        <div style="display: grid; grid-template-columns: {{ has_sidebar ? '7fr 5fr' : '1fr' }}; gap: var(--space-12);">
            {# Left column: Status + Progress #}
            <div style="display: flex; flex-direction: column; gap: var(--space-20);">
                {# Status card #}
                <div style="background: var(--surface-container-lowest); padding: var(--space-12); border-left: 12px solid var(--primary);">
                    <h2 class="bv-headline" style="font-size: 2rem; margin-bottom: var(--space-8);">{{ h.status_title|default('Hvad laver vi lige nu?') }}</h2>
                    <div style="display: flex; flex-direction: column; gap: var(--space-6); font-size: 1.125rem; color: var(--on-surface-variant); line-height: 1.7;">
                        {{ content|raw }}
                    </div>
                    {% if h.status_image %}
                    <div style="margin-top: var(--space-12);">
                        <img src="{{ h.status_image }}" alt="" style="width: 100%; height: 20rem; object-fit: cover; filter: grayscale(1); transition: filter 0.5s;" onmouseover="this.style.filter='grayscale(0)'" onmouseout="this.style.filter='grayscale(1)'"/>
                    </div>
                    {% endif %}
                </div>

                {# Progress bar #}
                {% if h.progress_title %}
                <div>
                    <h2 class="bv-headline" style="font-size: 2rem; margin-bottom: var(--space-8);">{{ h.progress_heading|default('Workshop Progress') }}</h2>
                    <div style="background: var(--surface-container); padding: var(--space-8);">
                        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: var(--space-4);">
                            <span style="font-family: var(--font-headline); font-weight: 700; font-size: 1.25rem; text-transform: uppercase; letter-spacing: 0.1em;">{{ h.progress_title }}</span>
                            <span style="font-family: var(--font-headline); font-weight: 900; font-size: 2.5rem; color: var(--tertiary);">{{ h.progress_percent }}% klar</span>
                        </div>
                        <div style="width: 100%; height: 3rem; background: var(--surface-container-highest); position: relative; overflow: hidden;">
                            <div style="height: 100%; background: var(--tertiary); width: {{ h.progress_percent }}%;"></div>
                        </div>
                        {% if h.progress_note %}
                        <p style="margin-top: var(--space-6); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--on-surface-variant); font-style: italic;">{{ h.progress_note }}</p>
                        {% endif %}
                    </div>
                </div>
                {% endif %}
            </div>

            {# Right column: Wishlist + Gallery CTA #}
            {% if has_sidebar %}
            <aside style="display: flex; flex-direction: column; gap: var(--space-12);">
                {# Wishlist #}
                {% if h.wishlist %}
                <div style="background: var(--surface-container-low); padding: var(--space-10);">
                    <div style="display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-10);">
                        <span class="material-symbols-outlined" style="color: var(--tertiary);">inventory_2</span>
                        <h2 class="bv-headline" style="font-size: 1.5rem;">&Oslash;nskelisten</h2>
                    </div>
                    <ul style="display: flex; flex-direction: column; gap: var(--space-4); list-style: none;">
                        {% for item in h.wishlist %}
                        <li style="display: flex; align-items: center; justify-content: space-between; padding: var(--space-4) var(--space-6); background: var(--surface-container-lowest); border-left: 4px solid transparent; transition: border-color 0.2s; cursor: pointer;" onmouseover="this.style.borderLeftColor='var(--secondary)'" onmouseout="this.style.borderLeftColor='transparent'">
                            <div style="display: flex; align-items: center; gap: var(--space-4);">
                                <span class="material-symbols-outlined" style="opacity: 0.4;">check_box_outline_blank</span>
                                <div>
                                    <span style="display: block; font-weight: 700; text-transform: uppercase; font-size: 0.875rem; letter-spacing: 0.1em;">{{ item.name }}</span>
                                    <span style="font-size: 0.625rem; text-transform: uppercase; color: var(--on-surface-variant);">{{ item.spec }}</span>
                                </div>
                            </div>
                            <span style="font-weight: 900; font-size: 0.875rem; color: {% if item.priority == 'kritisk' or item.priority == 'høj' %}var(--secondary){% else %}var(--on-surface-variant); opacity: 0.4{% endif %};">{{ item.priority|upper }}</span>
                        </li>
                        {% endfor %}
                    </ul>

                    {# Donation CTA — gated on gear_donation; the destination (accept gear inventory / intake form) is not yet built. #}
                    {% if h.donate_cta and feature_enabled('gear_donation') %}
                    <div style="margin-top: var(--space-10); padding: var(--space-6); background: var(--secondary-container); color: var(--on-secondary-container);">
                        <p style="font-family: var(--font-headline); font-weight: 700; text-transform: uppercase; font-size: 0.875rem; margin-bottom: var(--space-4);">{{ h.donate_heading|default('Har du noget liggende?') }}</p>
                        <p style="font-size: 0.875rem; margin-bottom: var(--space-6); line-height: 1.6;">{{ h.donate_text|default('Vi tager imod både nyt og brugt grej, så længe det virker.') }}</p>
                        <a href="{{ h.donate_url|default('#') }}" class="bv-btn bv-btn--secondary bv-btn--full" style="font-size: 0.875rem;">{{ h.donate_cta }}</a>
                    </div>
                    {% endif %}
                </div>
                {% endif %}

                {# Gallery CTA image #}
                {% if h.gallery_image %}
                <div style="position: relative; overflow: hidden; background: #18181b; aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center;">
                    <img src="{{ h.gallery_image }}" alt="Galleri" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.6; transition: transform 0.7s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"/>
                    <div style="position: relative; z-index: 1; text-align: center; padding: var(--space-8);">
                        <h3 style="font-family: var(--font-headline); font-weight: 900; color: #fff; text-transform: uppercase; font-size: 1.5rem; letter-spacing: -0.02em; margin-bottom: var(--space-4);">Se vores galleri</h3>
                        {% if feature_enabled('workshop_project_blueprints') %}
                        <a href="#" class="bv-btn bv-btn--outlined" style="color: #fff; border-color: #fff; font-size: 0.875rem;">Vis Projekter <span class="material-symbols-outlined" style="vertical-align: middle; font-size: 1rem;">arrow_forward</span></a>
                        {% endif %}
                    </div>
                </div>
                {% endif %}
            </aside>
            {% endif %}
        </div>
    </div>
</section>
