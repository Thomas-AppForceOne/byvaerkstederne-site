{% set h = page.header %}
<section class="bv-section" style="background: var(--surface-container-low);">
    <div class="bv-container">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: var(--space-12); gap: var(--space-8);">
            <div>
                {% if h.section_label %}
                <span class="bv-label" style="color: var(--{{ h.accent|default('tertiary') }}); letter-spacing: 0.2em; margin-bottom: var(--space-4); display: block;">{{ h.section_label }}</span>
                {% endif %}
                <h2 class="bv-headline" style="font-size: 2.5rem;">{{ h.section_title|default('Næste sessioner') }}</h2>
            </div>
            <div style="background: var(--surface-dim); height: 2px; flex: 1; max-width: 33%; margin-bottom: var(--space-4);"></div>
        </div>

        {% if h.intro %}
        <p class="bv-body-lg" style="max-width: 56rem; margin-bottom: var(--space-12);">{{ h.intro }}</p>
        {% endif %}

        {# Page-level accent (h.accent) is applied to every session. Per-session
           accent overrides are out of scope for sprint 1 per the source spec
           — the partial would honour event.accent if set, but this template
           feeds the page-level value uniformly. #}
        {% set _page_accent = h.accent|default('tertiary') %}

        <ul class="bv-event-list">
            {% for s in h.sessions %}
                {#
                   Meta-column rules per the source spec's atelier_sessions
                   mapping:
                     - s.no_signup: true  →  price = 'Drop-in', NO cta, NO capacity.
                       no_signup wins: if both no_signup AND contact_* are set,
                       the drop-in form takes precedence and the contact fields
                       are ignored.
                     - else if s.contact_name AND s.contact_sms set →
                       cta = { label: s.contact_name, href: 'sms:+45<digits>' }
                       (digits stripped of spaces).
                     - else: no meta slots.
                #}
                {% if s.no_signup %}
                    {% set _price = 'Drop-in' %}
                    {% set _cta = null %}
                {% elseif s.contact_name and s.contact_sms %}
                    {% set _price = null %}
                    {% set _cta = {
                        label: s.contact_name,
                        href: 'sms:+45' ~ (s.contact_sms|replace({' ': ''})),
                        variant: _page_accent
                    } %}
                {% else %}
                    {% set _price = null %}
                    {% set _cta = null %}
                {% endif %}

                {% set _event = {
                    day: s.day,
                    month: s.month,
                    title: s.title,
                    badge: s.badge|default(null),
                    time: s.time,
                    description: s.description,
                    accent: _page_accent,
                    filter: s.filter|default(h.filter|default(null)),
                    price: _price,
                    cta: _cta,
                    capacity: s.capacity|default(null),
                    featured: false
                } %}

                {% include 'partials/event_card.html.twig' with { event: _event, inList: true } %}
            {% endfor %}
        </ul>
    </div>
</section>
