{% set h = page.header %}
<section class="bv-section">
    <div class="bv-container">
        <div style="display: flex; gap: var(--space-20);">
            {# Left: Title + Donate #}
            <div style="width: 33%; flex-shrink: 0;">
                <h2 class="bv-headline" style="font-size: 3rem; line-height: 1; margin-bottom: var(--space-6);">{{ h.section_title|default('Vores Ønskeliste') }}</h2>
                <p class="bv-body-lg" style="margin-bottom: var(--space-8);">{{ h.section_subtitle|default('') }}</p>

                <div style="padding: var(--space-8); background: var(--secondary-fixed);">
                    <h4 style="font-weight: 700; text-transform: uppercase; margin-bottom: 0.5rem;">{{ h.donate_heading|default('Støt os økonomisk') }}</h4>
                    <p style="font-size: 0.875rem; margin-bottom: var(--space-4);">{{ h.donate_text|default('Alle bidrag går ubeskåret til inventar og udstyr til huset.') }}</p>
                    <a href="{{ h.donate_url|default('#') }}" class="bv-btn bv-btn--secondary bv-btn--full" style="font-size: 0.875rem;">{{ h.donate_cta|default('Donér via MobilePay') }}</a>
                </div>
            </div>

            {# Right: 2x2 icon cards #}
            <div style="flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8);">
                {# Pull from Flex Objects if available #}
                {% set flex = grav.get('flex_objects') %}{% set flex_dir = flex ? flex.directory('oenskeliste') : null %}{% set flex_wishes = flex_dir ? flex_dir.collection : null %}
                {% set wish_items = [] %}
                {% if flex_wishes is not null %}
                    {% for fitem in flex_wishes %}
                        {% if fitem.published and fitem.group == 'kulturhus' and not fitem.fulfilled %}
                            {% set wish_items = wish_items|merge([{icon: 'build', name: fitem.name, description: fitem.description|default('')}]) %}
                        {% endif %}
                    {% endfor %}
                {% endif %}
                {% set items_to_show = wish_items|length > 0 ? wish_items : h.items %}
                {% for item in items_to_show %}
                <div style="background: var(--surface-container-low); padding: var(--space-8); display: flex; align-items: flex-start; gap: var(--space-6);">
                    <span class="material-symbols-outlined" style="font-size: 2rem; color: var(--secondary);">{{ item.icon }}</span>
                    <div>
                        <h3 style="font-weight: 700; text-transform: uppercase; font-size: 1.125rem;">{{ item.name }}</h3>
                        <p style="font-size: 0.875rem; color: var(--on-surface-variant); margin-top: 0.5rem;">{{ item.description }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>
