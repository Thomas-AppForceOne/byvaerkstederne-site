{% set h = page.header %}
<section class="bv-section--sm">
    <div class="bv-container">
        <div style="background: var(--primary); color: var(--on-primary); padding: var(--space-12); display: flex; gap: var(--space-8); align-items: center;">
            <div style="flex: 1;">
                <h2 style="font-family: var(--font-headline); font-weight: 800; text-transform: uppercase; font-size: 1.75rem; margin-bottom: var(--space-4);">{{ h.contact_title|default('Pressekontakt') }}</h2>
                <div style="font-size: 1.25rem; font-weight: 600;">{{ h.contact_name|default('') }}</div>
                <div style="opacity: 0.8; margin-top: var(--space-2);">{{ h.contact_role|default('') }}</div>
                {% if h.contact_phone %}
                <div style="margin-top: var(--space-4); display: flex; align-items: center; gap: var(--space-2);">
                    <span class="material-symbols-outlined">phone</span> {{ h.contact_phone }}
                </div>
                {% endif %}
                {% if h.contact_email %}
                <div style="margin-top: var(--space-2); display: flex; align-items: center; gap: var(--space-2);">
                    <span class="material-symbols-outlined">mail</span>
                    <a href="mailto:{{ h.contact_email }}" style="color: var(--on-primary);">{{ h.contact_email }}</a>
                </div>
                {% endif %}
            </div>
            {% if page.media.images|first %}
            <div style="width: 8rem; height: 8rem; overflow: hidden; flex-shrink: 0;">
                <img src="{{ page.media.images|first.url }}" alt="{{ h.contact_name }}" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(1);"/>
            </div>
            {% endif %}
        </div>
    </div>
</section>
