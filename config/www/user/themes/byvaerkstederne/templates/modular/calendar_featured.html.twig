{% set h = page.header %}
<section class="bv-section--sm">
    <div class="bv-container">
        {# Canonical event-card migration (unification spec, step 11): the
           featured card renders through partials/event_card.html.twig with
           inList: false (single-card context → <div class="bv-event-item">
           wrapper, no surrounding <ul>) and featured: true (opts into the
           .bv-event-row--featured typography bump).

           Mapping per the spec's canonicalisation table:
             h.day_number → event.day, h.month → event.month,
             h.event_title → event.title, h.event_description → event.description,
             h.tag → event.badge, h.time → event.time,
             h.accent (optional, closed-set token) → event.accent.

           h.day_name, h.location, and the page image have no slot in the
           canonical model — the unification drops them. No live page renders
           this template (02.vaerkstedskalenderen/_03.featured was removed in
           the opening-day cleanup); a future re-enablement starts from the
           canonical contract. #}
        {% set _event = {
            day: h.day_number|default('25'),
            month: h.month|default('April'),
            title: h.event_title|default('Stor Arbejdsdag i Byværkstederne'),
            description: h.event_description|default(null),
            badge: h.tag|default(null),
            time: h.time|default(null),
            accent: h.accent|default('primary'),
            featured: true
        } %}
        {% include 'partials/event_card.html.twig' with { event: _event, inList: false } %}
    </div>
</section>
