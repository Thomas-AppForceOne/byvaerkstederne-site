{% set h = page.header %}
<section class="bv-section--sm">
    <div class="bv-container">
        <h2 class="bv-headline" style="font-size: 1.75rem; margin-bottom: var(--space-8);">{{ h.section_title|default('Kommende Aktiviteter') }}</h2>

        {# Pull from Flex Objects if available, fall back to page header. The
           canonical event-data shape (event.day, .month, .title, .badge,
           .time, .description, .accent, .filter, .price, .cta, .capacity,
           .featured) is what partials/event_card.html.twig consumes; build it
           here from whichever source has data. #}
        {% set flex = grav.get('flex_objects') %}{% set flex_dir = flex ? flex.directory('begivenheder') : null %}{% set flex_events = flex_dir ? flex_dir.collection : null %}

        {# filter_map maps the YAML 'group' field (filter ID candidates) to
           the data-filter value the calendar's filter buttons emit
           (templates/modular/calendar_filters.html.twig). Critical F1 guard:
           event.filter is fed FROM ev.group (the filter ID), event.accent is
           fed FROM ev.button_style (the colour token). Swapping these
           reproduces the v1 regression where data-group got the accent
           token and site.js's filter at site.js:687 matched nothing. #}
        {% set filter_map = {makerspace: 'makerspace', kreativ: 'kreativ', groenne: 'groenne', kulturhus: 'kulturhus', alle: 'all'} %}

        {% set events_list = [] %}
        {% if flex_events is not null %}
            {% for ev in flex_events %}
                {% if ev.published and not ev.featured %}
                    {% set _accent = ev.button_style|default('primary') %}
                    {% set _filter = filter_map[ev.group]|default(ev.group) %}
                    {% set _cta = (ev.button_text and ev.button_url)
                        ? { label: ev.button_text, href: ev.button_url, variant: _accent }
                        : null %}
                    {% set events_list = events_list|merge([{
                        day: ev.event_date|date('j'),
                        month: ev.event_date|date('M'),
                        title: ev.title,
                        badge: ev.badge,
                        time: ev.event_time,
                        description: ev.description,
                        accent: _accent,
                        filter: _filter,
                        price: ev.price,
                        cta: _cta,
                        capacity: ev.capacity,
                        featured: false
                    }]) %}
                {% endif %}
            {% endfor %}
        {% else %}
            {# Page-header fallback. Each event from h.events is already in the
               canonical shape (the YAML schema mirrors the partial's contract)
               OR carries the legacy {month, day, title, group, button_*} shape
               — normalise to canonical here so the partial doesn't need to
               know which source it came from. #}
            {% for ev in (h.events|default([])) %}
                {% set _accent = ev.accent|default(ev.button_style)|default('primary') %}
                {% set _filter = ev.filter|default(filter_map[ev.group]|default(ev.group)) %}
                {% set _cta = ev.cta is defined
                    ? ev.cta
                    : ((ev.button_text and ev.button_url)
                        ? { label: ev.button_text, href: ev.button_url, variant: _accent }
                        : null) %}
                {% set events_list = events_list|merge([{
                    day: ev.day,
                    month: ev.month,
                    title: ev.title,
                    badge: ev.badge,
                    time: ev.time,
                    description: ev.description,
                    accent: _accent,
                    filter: _filter,
                    price: ev.price,
                    cta: _cta,
                    capacity: ev.capacity,
                    featured: ev.featured|default(false)
                }]) %}
            {% endfor %}
        {% endif %}

        <ul class="bv-event-list">
            {% for event in events_list %}
                {% include 'partials/event_card.html.twig' with { event: event, inList: true } %}
            {% endfor %}
        </ul>
    </div>
</section>
