{% set h = page.header %}
<section class="bv-hero-text">
    <div class="bv-container">
        {% if h.badge %}
        <span class="bv-badge bv-badge--{{ h.badge_style|default('primary') }}">{{ h.badge }}</span>
        {% endif %}

        <h1 class="bv-display" style="font-size: clamp(2.5rem, 7vw, 5rem); margin-top: var(--space-4); max-width: 50rem;">
            {{ h.hero_heading|default(page.title) }}
        </h1>

        {% if h.subtitle %}
        <p class="bv-body-lg" style="margin-top: var(--space-6); max-width: 40rem;">{{ h.subtitle }}</p>
        {% endif %}

        {{ content|raw }}
    </div>
</section>
