{% set h = page.header %}
<section class="bv-section--sm">
    <div class="bv-container">
        {% if h.section_title %}
        <h2 class="bv-headline" style="font-size: 1.5rem; margin-bottom: var(--space-6);">{{ h.section_title }}</h2>
        {% endif %}

        <div style="display: flex; flex-direction: column; gap: var(--space-6);">
            {# Pull from Flex Objects if available, fall back to page header #}
            {% set flex = grav.get('flex_objects') %}{% set flex_dir = flex ? flex.directory('teammedlemmer') : null %}{% set flex_team = flex_dir ? flex_dir.collection : null %}
            {% if flex_team is not null %}
                {% for member in flex_team %}
                    {% if member.published and member.show_on_contact %}
                    <div class="bv-team-card">
                        <div class="bv-team-card__photo">
                            {% if member.photo %}
                            <img src="{{ member.photo }}" alt="{{ member.name }}"/>
                            {% endif %}
                        </div>
                        <div>
                            <div class="bv-team-card__name">{{ member.name }}</div>
                            <div class="bv-team-card__role">{{ member.role }}</div>
                            {% if member.email %}
                            <div class="bv-team-card__email">
                                <span class="material-symbols-outlined" style="font-size: 0.875rem;">mail</span>
                                <span>{{ member.email }}</span>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    {% endif %}
                {% endfor %}
            {% else %}
                {% for member in h.members %}
                <div class="bv-team-card">
                    <div class="bv-team-card__photo">
                        {% if member.photo %}
                        <img src="{{ member.photo }}" alt="{{ member.name }}"/>
                        {% endif %}
                    </div>
                    <div>
                        <div class="bv-team-card__name">{{ member.name }}</div>
                        <div class="bv-team-card__role">{{ member.role }}</div>
                        {% if member.email %}
                        <div class="bv-team-card__email">
                            <span class="material-symbols-outlined" style="font-size: 0.875rem;">mail</span>
                            <span>{{ member.email }}</span>
                        </div>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</section>
