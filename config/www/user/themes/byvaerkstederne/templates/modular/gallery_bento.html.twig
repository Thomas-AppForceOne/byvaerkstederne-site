{% set h = page.header %}
<section class="bv-section">
    <div class="bv-container">
        {% if h.section_title %}
        <h2 class="bv-headline" style="font-size: 1.75rem; margin-bottom: var(--space-8);">{{ h.section_title }}</h2>
        {% endif %}

        <div class="bv-bento">
            {% for item in h.images %}
            <div class="bv-bento__item{% if item.wide %} bv-bento__item--wide{% endif %}">
                {% if item.src %}
                <img src="{{ item.src }}" alt="{{ item.alt|default('') }}"/>
                {% endif %}
                {% if item.label %}
                <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: var(--space-4) var(--space-6); background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                    <span style="color: #fff; font-family: var(--font-headline); font-weight: 700; text-transform: uppercase;">{{ item.label }}</span>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>
</section>
