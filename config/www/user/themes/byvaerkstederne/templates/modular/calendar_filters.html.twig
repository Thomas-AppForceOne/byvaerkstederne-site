{% set h = page.header %}
<section class="bv-section--sm">
    <div class="bv-container">
        <div class="bv-filters">
            <span class="bv-label" style="margin-right: var(--space-4);">Filtr&eacute;r efter:</span>
            <button class="bv-filter-btn is-active" data-filter="all">
                <span class="bv-filter-dot bv-filter-dot--primary"></span>
                Alle aktiviteter
            </button>
            {% for filter in h.filters|default([
                {label: 'Makerspace & Reparation', group: 'secondary', filter: 'makerspace'},
                {label: 'Kreativ Fitness', group: 'tertiary', filter: 'kreativ'},
                {label: 'Grønt BYværksted', group: 'primary', filter: 'groenne'},
                {label: 'Kulturhus', group: 'kulturhus', filter: 'kulturhus'}
            ]) %}
            <button class="bv-filter-btn bv-filter-btn--{{ filter.group }}" data-filter="{{ filter.filter }}">
                <span class="bv-filter-dot bv-filter-dot--{{ filter.group }}"></span>
                {{ filter.label }}
            </button>
            {% endfor %}
        </div>
    </div>
</section>
