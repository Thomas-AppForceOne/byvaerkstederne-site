{% set h = page.header %}
<section style="position: relative; height: 90vh; min-height: 600px; display: flex; align-items: flex-end; overflow: hidden;">
    <div style="position: absolute; inset: 0; z-index: 0;">
        <img src="{{ h.bg_image_url }}" alt="{{ h.hero_heading }}" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) brightness(0.5) contrast(1.25);"/>
    </div>
    <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(24,24,27,0.9), transparent); z-index: 1;"></div>
    <div style="position: relative; z-index: 2; padding: var(--space-12); width: 100%; max-width: var(--container); margin: 0 auto;">
        <div style="border-left: 8px solid var(--secondary); padding-left: var(--space-8); margin-bottom: var(--space-12);">
            <h1 class="bv-display" style="font-size: clamp(3rem, 9vw, 8rem); color: #fff;">{{ h.hero_heading|default(page.title) }}</h1>
        </div>
        <p style="max-width: 42rem; font-size: 1.25rem; color: rgba(212,212,216,0.9); line-height: 1.7;">{{ h.subtitle }}</p>
    </div>
</section>
