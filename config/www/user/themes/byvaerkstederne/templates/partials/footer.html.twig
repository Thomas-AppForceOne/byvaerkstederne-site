<footer class="bv-footer">
    <div class="bv-footer__grid">
        {# Brand & About #}
        <div class="bv-footer__brand">
            <div class="bv-footer__logo">Byv&aelig;rkstederne</div>
            <p class="bv-footer__about">Et brugerdrevet v&aelig;rkstedsf&aelig;llesskab i Hundested, hvor vi skaber fremtidens rammer sammen.</p>
        </div>

        {# Værksteder #}
        <div class="bv-footer__col">
            <h3 class="bv-footer__heading">V&aelig;rksteder</h3>
            <nav class="bv-footer__nav">
                <a href="/vaerksteder/makerspace">Makerspace &amp; Reparation</a>
                <a href="/vaerksteder/kreativ-fitness">Kreativ Fitness</a>
                <a href="/vaerksteder/det-groenne-faellesskab">Det Gr&oslash;nne F&aelig;llesskab</a>
                <a href="/vaerksteder/kulturhus">Kulturhus</a>
            </nav>
        </div>

        {# Information #}
        <div class="bv-footer__col">
            <h3 class="bv-footer__heading">Information</h3>
            <nav class="bv-footer__nav">
                <a href="/vedtaegter">Vedt&aelig;gter</a>
                <a href="/privatlivspolitik">Privatlivspolitik</a>
                <a href="/referater">Referater</a>
                <a href="/presse">Presse</a>
            </nav>
        </div>

        {# Fællesskab — authenticated users only #}
