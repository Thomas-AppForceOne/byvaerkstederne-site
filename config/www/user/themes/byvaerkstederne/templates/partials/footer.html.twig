            <h3 class="bv-footer__heading">F&aelig;llesskab</h3>
            <nav class="bv-footer__nav">
                <a href="/roadmap">Roadmap</a>
                <button type="button" onclick="bvFeatureSuggestion.open(); return false;">Forsl&aring; feature</button>
                <button type="button" onclick="bvBugReport.open(); return false;">Rapport&eacute;r fejl</button>
            </nav>
        </div>
        {% endif %}

        {# Find os #}
        <div class="bv-footer__col">
            <h3 class="bv-footer__heading">Find os</h3>
            <div class="bv-footer__contact">
                <div class="bv-footer__contact-item">
                    <span class="material-symbols-outlined">location_on</span>
                    <span>N&oslash;rregade 11,<br/>3390 Hundested</span>
                </div>
                <div class="bv-footer__contact-item">
                    <span class="material-symbols-outlined">mail</span>
                    <a href="mailto:kontakt@byvaerkstederne.dk">kontakt@byvaerkstederne.dk</a>
                </div>
            </div>
        </div>
    </div>

    <div class="bv-footer__bottom">
        <div class="bv-footer__bottom-inner">
            <span class="bv-footer__copyright">&copy; 2026 BYV&AElig;RKSTEDERNE I HUNDESTED.</span>
            <div class="bv-footer__social">
