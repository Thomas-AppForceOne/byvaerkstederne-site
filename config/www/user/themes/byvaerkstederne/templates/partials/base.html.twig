<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{% if page.title %}{{ page.title }} | {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ page.header.metadata.description ?: page.summary|striptags|truncate(160) ?: site.metadata.description }}"/>

    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=Work+Sans:wght@300..700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

    <link href="{{ url('theme://css/theme.css') }}?v={{ 'now'|date('U') }}" rel="stylesheet"/>

    {% block head %}{% endblock %}
</head>
<body class="bv-body{% block body_classes %} {{ page.header.body_classes }}{% endblock %}">

    {% block header %}
        {% include 'partials/navigation.html.twig' %}
    {% endblock %}

    <main class="bv-main blueprint-grid">
        {% block hero %}{% endblock %}
        {% block body %}
            {{ content|raw }}
        {% endblock %}
    </main>

    {% block footer %}
        {% include 'partials/footer.html.twig' %}
    {% endblock %}

    {% include 'partials/login_overlay.html.twig' %}
    {% if feature_enabled('bug_report') %}
    {% include 'partials/bug_report_overlay.html.twig' %}
    {% endif %}
    {% if feature_enabled('feature_suggestion') %}
    {% include 'partials/feature_suggestion_overlay.html.twig' %}
    {% endif %}

    <script src="{{ url('theme://js/site.js') }}?v={{ 'now'|date('U') }}"></script>

    {% block bottom %}{% endblock %}
</body>
</html>
