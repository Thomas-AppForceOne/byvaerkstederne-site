{# Feature Suggestion Overlay — modal panel for authenticated members only #}
{% if grav.user.authenticated and grav.user.authorized %}
{# Generate nonce for CSRF protection #}
{% set fs_nonce = nonce_field('feature-suggestion-form', 'fs_nonce') %}

{# Overlay backdrop + panel — NO floating trigger button (opened programmatically only) #}
<div
    id="bv-feature-suggestion-overlay"
    class="bv-feature-suggestion-overlay"
    role="dialog"
    aria-modal="true"
    aria-labelledby="bv-fs-overlay-title"
    aria-hidden="true">

    <div class="bv-feature-suggestion-overlay__panel">

        {# Header #}
        <div class="bv-feature-suggestion-overlay__header">
            <div class="bv-feature-suggestion-overlay__header-inner">
                <div class="bv-feature-suggestion-overlay__header-meta">
                    <span class="material-symbols-outlined" aria-hidden="true" style="color: var(--secondary-fixed-dim); font-size: 1.25rem;">lightbulb</span>
                    <span class="bv-feature-suggestion-overlay__version">Feature-forslag v1.0</span>
                </div>
                <h2 id="bv-fs-overlay-title" class="bv-feature-suggestion-overlay__title">
                    Forsl&aring; ny <span style="color: var(--secondary-fixed-dim);">Feature</span>
                </h2>
            </div>
            <button
                class="bv-feature-suggestion-overlay__close"
                id="bv-fs-overlay-close"
                type="button"
                aria-label="Luk feature-forslag-dialog">
                <span class="material-symbols-outlined" aria-hidden="true">close</span>
            </button>
        </div>

        {# Scrollable body #}
        <div class="bv-feature-suggestion-overlay__body" id="bv-fs-overlay-body">

            {# Error/success messages #}
            <div id="bv-fs-overlay-message" class="bv-fs-message" aria-live="polite" style="display:none;"></div>

            {# Confirmation target — populated by JS on success, hidden by default #}
            <div id="bv-fs-overlay-confirmation" class="bv-fs-confirmation" role="status" style="display:none;"></div>

            <form
                id="bv-fs-overlay-form"
                class="bv-fs-form"
                novalidate>

                {{ fs_nonce|raw }}
                <input type="hidden" name="submission_token" id="bv-fs-overlay-submission-token" value="">

                {# Field: Title #}
                <div class="bv-fs-field">
                    <label class="bv-fs-label" for="bv-fs-overlay-title-input">
                        Hvad er din id&eacute;?
                        <span class="bv-fs-required" aria-label="påkrævet">*</span>
                    </label>
                    <input
                        type="text"
                        id="bv-fs-overlay-title-input"
                        name="fs_title"
                        class="bv-input bv-fs-title-input"
                        placeholder="Kort og præcis overskrift..."
                        required
                        aria-required="true"
                        aria-describedby="bv-fs-overlay-title-error"/>
                    <div id="bv-fs-overlay-title-error" class="bv-fs-field-error" role="alert" aria-live="polite"></div>
                </div>

                {# Field: Description #}
                <div class="bv-fs-field">
                    <label class="bv-fs-label" for="bv-fs-overlay-description">
                        Beskrivelse af id&eacute;en
                        <span class="bv-fs-required" aria-label="påkrævet">*</span>
                    </label>
                    <textarea
                        id="bv-fs-overlay-description"
                        name="fs_description"
                        class="bv-input bv-textarea bv-fs-textarea"
                        placeholder="Giv os detaljerne om hvordan det skal fungere..."
                        rows="5"
                        required
                        aria-required="true"
                        aria-describedby="bv-fs-overlay-description-error"></textarea>
                    <div id="bv-fs-overlay-description-error" class="bv-fs-field-error" role="alert" aria-live="polite"></div>
                </div>

                {# Field: Community Value #}
                <div class="bv-fs-field">
                    <label class="bv-fs-label" for="bv-fs-overlay-community-value">
                        V&aelig;rdi for f&aelig;llesskabet
                        <span class="bv-fs-required" aria-label="påkrævet">*</span>
                    </label>
                    <textarea
                        id="bv-fs-overlay-community-value"
                        name="fs_community_value"
                        class="bv-input bv-textarea bv-fs-textarea bv-fs-textarea--sm"
                        placeholder="Hvorfor er dette vigtigt for Byværkstederne?"
                        rows="3"
                        required
                        aria-required="true"
                        aria-describedby="bv-fs-overlay-community-value-error"></textarea>
                    <div id="bv-fs-overlay-community-value-error" class="bv-fs-field-error" role="alert" aria-live="polite"></div>
                </div>

            </form>
        </div>

        {# Footer action row #}
        <div class="bv-feature-suggestion-overlay__footer">
            <button
                type="button"
                class="bv-feature-suggestion-cancel"
                id="bv-fs-overlay-cancel-btn">
                Afbryd
            </button>
            <button
                type="button"
                id="bv-fs-overlay-submit"
                class="bv-btn bv-btn--primary"
                style="display: flex; align-items: center; gap: var(--space-2);">
                Indsend forslag
                <span class="material-symbols-outlined" aria-hidden="true" style="font-size: 1.125rem;">arrow_forward</span>
            </button>
        </div>

        {# Colour accent strip #}
        <div class="bv-feature-suggestion-accent-strip" aria-hidden="true">
            <div style="background: var(--primary);"></div>
            <div style="background: var(--secondary);"></div>
            <div style="background: var(--tertiary);"></div>
        </div>

    </div>{# /.panel #}
</div>{# /.overlay #}

{% else %}
{# Unauthenticated: no overlay rendered #}
{% endif %}
