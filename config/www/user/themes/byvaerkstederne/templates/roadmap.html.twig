{% extends 'partials/base.html.twig' %}

{# ============================================================================
   Roadmap page
   Displays tabbed views: Alle / Fejl (bugs) / Feature-forslag (features).
   Voting requires authentication. Public access for view only.
   ============================================================================ #}

{% set is_auth = grav.user.authenticated and grav.user.authorized %}

{# ── Hero section — matches bv-hero-text structural pattern ────────────────── #}
{% block hero %}
<section class="bv-hero-text">
    <div class="bv-container">
        {% if page.header.badge %}
        <span class="bv-badge bv-badge--{{ page.header.badge_style|default('primary') }}">{{ page.header.badge }}</span>
        {% endif %}
        <h1 class="bv-display" style="font-size: clamp(2.5rem, 7vw, 5rem); margin-top: var(--space-4); max-width: 50rem;">
            {{ page.header.hero_heading|default(page.title) }}
        </h1>
        {% if page.header.subtitle %}
        <p class="bv-body-lg" style="margin-top: var(--space-6); max-width: 44rem;">{{ page.header.subtitle }}</p>
        {% endif %}

        {# CTA row #}
        <div class="bv-rm-hero-cta" style="margin-top: var(--space-8); display: flex; flex-wrap: wrap; gap: var(--space-4); align-items: center;">
            <a href="/foreslaa-feature" class="bv-btn bv-btn--primary">
                Foresl&aring; en feature
                <span class="material-symbols-outlined" aria-hidden="true" style="font-size:1rem;vertical-align:middle;margin-left:0.25rem;">arrow_forward</span>
            </a>
            {% if is_auth %}
            <button
                type="button"
                class="bv-btn bv-btn--outline"
                onclick="bvBugReport.open(); return false;"
                aria-haspopup="dialog">
                <span class="material-symbols-outlined" aria-hidden="true" style="font-size:1rem;vertical-align:middle;margin-right:0.25rem;">bug_report</span>
                Rapport&eacute;r fejl
            </button>
            {% else %}
            <button
                type="button"
                class="bv-btn bv-btn--outline"
                onclick="document.getElementById('bv-login-overlay').classList.add('is-open'); document.body.style.overflow='hidden'; return false;"
                aria-haspopup="dialog">
                <span class="material-symbols-outlined" aria-hidden="true" style="font-size:1rem;vertical-align:middle;margin-right:0.25rem;">bug_report</span>
                Rapport&eacute;r fejl
            </button>
            {% endif %}
        </div>
    </div>
</section>
{% endblock %}

{% block body %}
<section class="bv-rm-page" aria-label="Website Roadmap">
<div class="bv-container">

    {# ── Platform status & version badges ────────────────────────────────── #}
    <div class="bv-rm-info-row">
        <div class="bv-rm-header__badges" role="status" aria-label="Platform status">
            <span class="bv-rm-badge bv-rm-badge--status">
                <span class="bv-rm-badge__dot" aria-hidden="true"></span>
                System Status: {{ platform_status|e }}
            </span>
            <span class="bv-rm-badge bv-rm-badge--version">
                Version {{ platform_version|e }}
            </span>
        </div>

        {# "Forstå processen" button #}
        <button
            type="button"
            id="bv-rm-process-btn"
            class="bv-btn bv-btn--outline bv-rm-process-btn"
            aria-haspopup="dialog"
            aria-expanded="false"
            aria-controls="bv-rm-process-panel">
            <span class="material-symbols-outlined" aria-hidden="true">info</span>
            Forstå processen
        </button>
    </div>

    {# ── "Forstå processen" overlay panel ─────────────────────────────────── #}
    <div
        id="bv-rm-process-panel"
        class="bv-rm-process-overlay"
        role="dialog"
        aria-modal="true"
        aria-label="Forstå processen"
        aria-hidden="true">
        <div class="bv-rm-process-overlay__inner">
            <div class="bv-rm-process-overlay__header">
                <h2 class="bv-rm-process-overlay__title">Sådan fungerer det</h2>
                <button
                    type="button"
                    id="bv-rm-process-close"
                    class="bv-rm-process-overlay__close"
                    aria-label="Luk panel">
                    <span class="material-symbols-outlined" aria-hidden="true">close</span>
                </button>
            </div>

            <div class="bv-rm-process-overlay__body">
                <div class="bv-rm-process-grid">

                    {# Left: Voting & selection #}
                    <div class="bv-rm-process-section">
                        <h3 class="bv-rm-process-section__title">
                            <span class="material-symbols-outlined" aria-hidden="true">star</span>
                            Stemmeafgivelse
                        </h3>
                        <p>
                            Hvert logget ind medlem tildeles <strong>6 stemmer i alt</strong>:
                            3 til "Registrerede Website-fejl" og 3 til "Forslag til Websitet".
                            Dine stemmer hjælper os se hvad der er vigtigst for fællesskabet.
                        </p>
                        <p>
                            Du kan <strong>trække en stemme tilbage</strong> og genbruge den på et andet emne —
                            stemmerne er ikke permanente, så du kan ændre prioritering.
                        </p>

                        <h3 class="bv-rm-process-section__title" style="margin-top: var(--space-8);">
                            <span class="material-symbols-outlined" aria-hidden="true">lock_open</span>
                            Frigivelse af stemmer
                        </h3>
                        <p>
                            Når et emne når status <strong>"Klar til implementation"</strong>,
                            frigives alle stemmer afgivet på det emne automatisk tilbage til
                            stemmernes ejeres budget. Du kan nu bruge disse stemmer et andet sted.
                            Din stemmehistorik for emnet bevares stadig.
                        </p>

                        <h3 class="bv-rm-process-section__title" style="margin-top: var(--space-8);">
                            <span class="material-symbols-outlined" aria-hidden="true">playlist_add_check</span>
                            Udvælgelse
                        </h3>
                        <p>
                            Vi gennemgår regelmæssigt de mest stemte emner.
                            Valget baseres på en kombination af <strong>stemmetal</strong>,
                            <strong>teknisk sværhedsgrad</strong> og
                            <strong>overordnet værdi</strong> for platformen.
                        </p>
                    </div>

                    {# Right: Status workflow #}
                    <div class="bv-rm-process-statuses">
                        <h3 class="bv-rm-process-section__title">Status &amp; Workflow</h3>
                        <div class="bv-rm-process-status-list" role="list">
                            <div class="bv-rm-process-status" role="listitem">
                                <div class="bv-rm-process-status__bar bv-rm-process-status__bar--rapporteret"></div>
                                <div>
                                    <span class="bv-rm-status-badge bv-rm-status--rapporteret">Rapporteret</span>
                                    <p>Emnet er modtaget og venter på indledende gennemsyn.</p>
                                </div>
                            </div>
                            <div class="bv-rm-process-status" role="listitem">
                                <div class="bv-rm-process-status__bar bv-rm-process-status__bar--under-afklaring"></div>
                                <div>
                                    <span class="bv-rm-status-badge bv-rm-status--under-afklaring">Under afklaring</span>
                                    <p>Vi undersøger fejlen eller planlægger hvordan featuren skal bygges.</p>
                                </div>
                            </div>
                            <div class="bv-rm-process-status" role="listitem">
                                <div class="bv-rm-process-status__bar bv-rm-process-status__bar--klar-til-implementation"></div>
                                <div>
                                    <span class="bv-rm-status-badge bv-rm-status--klar-til-implementation">Klar til implementation</span>
                                    <p>Løsningen er defineret og klar til at blive kodet. Stemmer frigives.</p>
                                </div>
                            </div>
                            <div class="bv-rm-process-status" role="listitem">
                                <div class="bv-rm-process-status__bar bv-rm-process-status__bar--under-implementation"></div>
                                <div>
                                    <span class="bv-rm-status-badge bv-rm-status--under-implementation">Under implementation</span>
                                    <p>Der arbejdes aktivt på sagen. Stemmeafgivelse er låst.</p>
                                </div>
                            </div>
                            <div class="bv-rm-process-status" role="listitem">
                                <div class="bv-rm-process-status__bar bv-rm-process-status__bar--klar-til-test"></div>
                                <div>
                                    <span class="bv-rm-status-badge bv-rm-status--klar-til-test">Klar til test</span>
                                    <p>Bygget og i kvalitetsgennemsyn. Stemmeafgivelse er låst.</p>
                                </div>
                            </div>
                            <div class="bv-rm-process-status" role="listitem">
                                <div class="bv-rm-process-status__bar bv-rm-process-status__bar--loest"></div>
                                <div>
                                    <span class="bv-rm-status-badge bv-rm-status--loest">Løst</span>
                                    <p>Afsendt og live. Emnet vises stadig for transparens.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>{# /.bv-rm-process-grid #}
            </div>{# /.bv-rm-process-overlay__body #}
        </div>{# /.bv-rm-process-overlay__inner #}
    </div>{# /#bv-rm-process-panel #}

    {# ── Nonce for vote requests (authenticated only) ─────────────────────── #}
    {% if is_auth %}
    <div id="bv-rm-vote-nonces" style="display:none;" aria-hidden="true">
        {{ nonce_field('roadmap-vote', 'vote_nonce')|raw }}
    </div>
    {% endif %}

    {# ── Tab navigation ───────────────────────────────────────────────────── #}
    <div class="bv-rm-tabs" role="tablist" aria-label="Filtrer roadmap">
        <button
            class="bv-rm-tab is-active"
            role="tab"
            id="bv-rm-tab-alle"
            aria-selected="true"
            aria-controls="bv-rm-tabpanel-alle"
            data-tab="alle">
            Alle
            <span class="bv-rm-tab__count">{{ roadmap_all_items|length }}</span>
        </button>
        <button
            class="bv-rm-tab"
            role="tab"
            id="bv-rm-tab-fejl"
            aria-selected="false"
            aria-controls="bv-rm-tabpanel-fejl"
            data-tab="fejl">
            Fejl
            <span class="bv-rm-tab__count">{{ roadmap_bugs|length }}</span>
        </button>
        <button
            class="bv-rm-tab"
            role="tab"
            id="bv-rm-tab-feature-forslag"
            aria-selected="false"
            aria-controls="bv-rm-tabpanel-feature-forslag"
            data-tab="feature-forslag">
            Features
            <span class="bv-rm-tab__count">{{ roadmap_features|length }}</span>
        </button>
    </div>

    {# ── Filter toolbar ──────────────────────────────────────────────────── #}
    <div class="bv-rm-filter-bar" role="search" aria-label="Filtrer roadmap-emner">
        <div class="bv-rm-filter-bar__group">
            <label class="bv-rm-filter-bar__label" for="bv-rm-filter-status">Status</label>
            <select id="bv-rm-filter-status" class="bv-rm-filter-select" aria-label="Filtrer efter status">
                <option value="">Alle statusser</option>
                <option value="rapporteret">Rapporteret</option>
                <option value="under_afklaring">Under afklaring</option>
                <option value="klar_til_implementation">Klar til implementation</option>
                <option value="under_implementation">Under implementation</option>
                <option value="klar_til_test">Klar til test</option>
                <option value="loest">L&oslash;st</option>
            </select>
        </div>
        <div class="bv-rm-filter-bar__group">
            <label class="bv-rm-filter-bar__label" for="bv-rm-filter-priority">Prioritet</label>
            <select id="bv-rm-filter-priority" class="bv-rm-filter-select" aria-label="Filtrer efter prioritet">
                <option value="">Alle prioriteter</option>
                <option value="kritisk">Kritisk</option>
                <option value="hoej">H&oslash;j</option>
                <option value="middel">Middel</option>
                <option value="lav">Lav</option>
                <option value="nyhed">Nyhed</option>
                <option value="forbedring">Forbedring</option>
            </select>
        </div>
        <button type="button" id="bv-rm-filter-clear" class="bv-rm-filter-clear" aria-label="Nulstil filtre" hidden>
            <span class="material-symbols-outlined" aria-hidden="true">filter_alt_off</span>
            Nulstil
        </button>
    </div>

    {# ── "Vis løste" toggle ───────────────────────────────────────────────── #}
    <div class="bv-rm-solved-toggle-row" style="margin-bottom: var(--space-4);">
        <button
            type="button"
            id="bv-rm-show-solved"
            class="bv-rm-solved-toggle"
            aria-pressed="false"
            aria-controls="bv-rm-solved-hint">
            <span class="material-symbols-outlined" aria-hidden="true">visibility</span>
            Vis l&oslash;ste
            <span class="bv-rm-solved-toggle__count" id="bv-rm-solved-count"></span>
        </button>
        <span id="bv-rm-solved-hint" class="bv-rm-solved-toggle__hint"></span>
    </div>

    {# ── Tab panels ───────────────────────────────────────────────────────── #}

    {# Alle — combined bugs + features sorted by timestamp #}
    <div
        id="bv-rm-tabpanel-alle"
        class="bv-rm-tabpanel"
        role="tabpanel"
        aria-labelledby="bv-rm-tab-alle">

        {% if roadmap_all_items is empty %}
            <div class="bv-rm-empty-state">
                <span class="material-symbols-outlined bv-rm-empty-state__icon" aria-hidden="true">inventory_2</span>
                <h2 class="bv-rm-empty-state__title">Roadmap er tomt</h2>
                <p class="bv-rm-empty-state__text">
                    Ingen emner er tilgængelige endnu. Vær den første til at
                    <a href="/roadmap#report" onclick="document.getElementById('bv-bug-overlay').classList.add('is-open'); document.body.style.overflow='hidden'; return false;" class="bv-rm-empty-state__link">rapportere en fejl</a>
                    eller
                    <a href="/foreslaa-feature" class="bv-rm-empty-state__link">foreslå en ny feature</a>.
                </p>
            </div>
        {% else %}
            <div class="bv-rm-cards" role="list">
                {% for item_id, item in roadmap_all_items %}
                    {% include 'partials/roadmap_card.html.twig' with {
                        item: item,
                        item_id: item_id,
                        is_auth: is_auth,
                        user_voted: item_id in roadmap_user_voted_items,
                        bug_budget: roadmap_bug_budget,
                        feature_budget: roadmap_feature_budget,
                        use_canonical_id: false
                    } only %}
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# Fejl — bugs only #}
    <div
        id="bv-rm-tabpanel-fejl"
        class="bv-rm-tabpanel"
        role="tabpanel"
        aria-labelledby="bv-rm-tab-fejl"
        hidden>

        {% if is_auth %}
        <div class="bv-rm-budget" id="bv-rm-bug-budget" aria-live="polite" aria-label="Tilbageværende fejlstemmer">
            <span class="bv-rm-budget__label">Stemmer til rådighed</span>
            <span class="bv-rm-budget__count" id="bv-rm-bug-budget-count">{{ roadmap_bug_budget }}</span>
            <span class="bv-rm-budget__word">stemmer tilbage</span>
        </div>
        {% endif %}

        {% if roadmap_bugs is empty %}
            <div class="bv-rm-empty-state">
                <span class="material-symbols-outlined bv-rm-empty-state__icon" aria-hidden="true">bug_report</span>
                <h2 class="bv-rm-empty-state__title">Ingen registrerede fejl</h2>
                <p class="bv-rm-empty-state__text">
                    Ingen fejl er rapporteret endnu — godt arbejde! Hvis du opdager en fejl,
                    <a href="#" onclick="document.getElementById('bv-bug-overlay').classList.add('is-open'); document.body.style.overflow='hidden'; return false;" class="bv-rm-empty-state__link">klik her for at rapportere den</a>.
                </p>
            </div>
        {% else %}
            <div class="bv-rm-cards" role="list">
                {% for item_id, item in roadmap_bugs %}
                    {% include 'partials/roadmap_card.html.twig' with {
                        item: item,
                        item_id: item_id,
                        is_auth: is_auth,
                        user_voted: item_id in roadmap_user_voted_items,
                        bug_budget: roadmap_bug_budget,
                        feature_budget: roadmap_feature_budget,
                        use_canonical_id: true
                    } only %}
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# Feature-forslag — features only #}
    <div
        id="bv-rm-tabpanel-feature-forslag"
        class="bv-rm-tabpanel"
        role="tabpanel"
        aria-labelledby="bv-rm-tab-feature-forslag"
        hidden>

        {% if is_auth %}
        <div class="bv-rm-budget" id="bv-rm-feature-budget" aria-live="polite" aria-label="Tilbageværende forslagsstemmer">
            <span class="bv-rm-budget__label">Stemmer til rådighed</span>
            <span class="bv-rm-budget__count" id="bv-rm-feature-budget-count">{{ roadmap_feature_budget }}</span>
            <span class="bv-rm-budget__word">stemmer tilbage</span>
        </div>
        {% endif %}

        {% if roadmap_features is empty %}
            <div class="bv-rm-empty-state">
                <span class="material-symbols-outlined bv-rm-empty-state__icon" aria-hidden="true">lightbulb</span>
                <h2 class="bv-rm-empty-state__title">Ingen feature-forslag endnu</h2>
                <p class="bv-rm-empty-state__text">
                    Har du en idé til en ny funktion?
                    <a href="/foreslaa-feature" class="bv-rm-empty-state__link">Indsend dit forslag her</a>
                    og vær med til at forme fremtiden for platformen.
                </p>
            </div>
        {% else %}
            <div class="bv-rm-cards" role="list">
                {% for item_id, item in roadmap_features %}
                    {% include 'partials/roadmap_card.html.twig' with {
                        item: item,
                        item_id: item_id,
                        is_auth: is_auth,
                        user_voted: item_id in roadmap_user_voted_items,
                        bug_budget: roadmap_bug_budget,
                        feature_budget: roadmap_feature_budget,
                        use_canonical_id: true
                    } only %}
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# ── Unauthenticated vote prompt ───────────────────────────────────────── #}
    {% if not is_auth %}
    <div class="bv-rm-login-notice" role="complementary" aria-label="Log ind for at stemme">
        <span class="material-symbols-outlined" aria-hidden="true">how_to_vote</span>
        <span>
            <a
                href="#"
                class="bv-rm-login-notice__link"
                onclick="document.getElementById('bv-login-overlay').classList.add('is-open'); document.body.style.overflow='hidden'; return false;">
                Log ind
            </a>
            for at se din stemmeoversigt og stemme på emner.
        </span>
    </div>
    {% endif %}

    {# ── Inline error toast container ─────────────────────────────────────── #}
    <div id="bv-rm-toast" class="bv-rm-toast" role="status" aria-live="polite" aria-atomic="true"></div>

</div>{# /.bv-container #}
</section>
{% endblock %}

{% block bottom %}
<script>
(function () {
    'use strict';

    /* ── Data passed from PHP ─────────────────────────────────────────────── */
    var AUTH      = {{ is_auth ? 'true' : 'false' }};
    var BUG_BUD   = {{ roadmap_bug_budget|default(3) }};
    var FEAT_BUD  = {{ roadmap_feature_budget|default(3) }};
    var VOTED     = {{ roadmap_user_voted_items|default([])|json_encode|raw }};

    /* Nonce is read from the hidden input rendered by nonce_field() */
    function getVoteNonce() {
        var el = document.querySelector('#bv-rm-vote-nonces [name="vote_nonce"]');
        return el ? el.value : '';
    }

    /* ── Tab switching ────────────────────────────────────────────────────── */
    var tabs = document.querySelectorAll('.bv-rm-tab[role="tab"]');
    var panels = document.querySelectorAll('.bv-rm-tabpanel[role="tabpanel"]');

    tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
            // Deactivate all tabs
            tabs.forEach(function (t) {
                t.classList.remove('is-active');
                t.setAttribute('aria-selected', 'false');
            });
            // Hide all panels
            panels.forEach(function (p) {
                p.setAttribute('hidden', '');
            });
            // Activate clicked tab
            tab.classList.add('is-active');
            tab.setAttribute('aria-selected', 'true');
            // Show corresponding panel
            var panelId = tab.getAttribute('aria-controls');
            var panel = document.getElementById(panelId);
            if (panel) {
                panel.removeAttribute('hidden');
            }
        });

        // Keyboard: arrow keys for tab navigation
        tab.addEventListener('keydown', function (e) {
            var tabList = Array.from(tabs);
            var currentIndex = tabList.indexOf(tab);
            if (e.key === 'ArrowRight') {
                e.preventDefault();
                tabList[(currentIndex + 1) % tabList.length].focus();
            } else if (e.key === 'ArrowLeft') {
                e.preventDefault();
                tabList[(currentIndex - 1 + tabList.length) % tabList.length].focus();
            }
        });
    });

    /* ── "Forstå processen" panel ─────────────────────────────────────────── */
    var processBtn   = document.getElementById('bv-rm-process-btn');
    var processPanel = document.getElementById('bv-rm-process-panel');
    var processClose = document.getElementById('bv-rm-process-close');

    if (processBtn && processPanel) {
        processBtn.addEventListener('click', function () {
            openProcessPanel();
        });

        if (processClose) {
            processClose.addEventListener('click', function () {
                closeProcessPanel();
            });
        }

        // Close on backdrop click
        processPanel.addEventListener('click', function (e) {
            if (e.target === processPanel) {
                closeProcessPanel();
            }
        });

        // Close on Escape key; trap focus inside panel
        document.addEventListener('keydown', function (e) {
            if (!processPanel.classList.contains('is-open')) return;

            if (e.key === 'Escape') {
                closeProcessPanel();
                return;
            }

            if (e.key === 'Tab') {
                var focusable = Array.from(processPanel.querySelectorAll(
                    'button:not([disabled]), [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
                ));
                if (!focusable.length) { e.preventDefault(); return; }
                var first = focusable[0];
                var last  = focusable[focusable.length - 1];
                if (e.shiftKey) {
                    if (document.activeElement === first) { e.preventDefault(); last.focus(); }
                } else {
                    if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
                }
            }
        });
    }

    function openProcessPanel() {
        if (!processPanel) return;
        processPanel.classList.add('is-open');
        processPanel.setAttribute('aria-hidden', 'false');
        processBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        if (processClose) {
            setTimeout(function () { processClose.focus(); }, 50);
        }
    }

    function closeProcessPanel() {
        if (!processPanel) return;
        processPanel.classList.remove('is-open');
        processPanel.setAttribute('aria-hidden', 'true');
        processBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        if (processBtn) {
            try { processBtn.focus(); } catch (e) {}
        }
    }

    /* ── Helper: toggle a card's action bar ──────────────────────────────── */
    function toggleCard(card) {
        var isOpen = card.classList.contains('is-expanded');

        // Close all other cards
        document.querySelectorAll('.bv-rm-card.is-expanded').forEach(function (c) {
            if (c !== card) {
                c.classList.remove('is-expanded');
                c.setAttribute('aria-expanded', 'false');
                var bar = c.querySelector('.bv-rm-card__action-bar');
                if (bar) bar.setAttribute('hidden', '');
            }
        });

        // Toggle this one
        if (isOpen) {
            card.classList.remove('is-expanded');
            card.setAttribute('aria-expanded', 'false');
            var bar = card.querySelector('.bv-rm-card__action-bar');
            if (bar) bar.setAttribute('hidden', '');
        } else {
            card.classList.add('is-expanded');
            card.setAttribute('aria-expanded', 'true');
            var bar = card.querySelector('.bv-rm-card__action-bar');
            if (bar) bar.removeAttribute('hidden');
        }
    }

    /* ── Card click → inline action bar ──────────────────────────────────── */
    document.querySelectorAll('.bv-rm-card[data-item-id]').forEach(function (card) {
        card.addEventListener('click', function (e) {
            // If the face vote button was clicked, handle vote directly (not action bar)
            var faceVoteBtn = e.target.closest('.bv-rm-card__vote-btn');
            if (faceVoteBtn && faceVoteBtn.tagName === 'BUTTON') {
                e.stopPropagation();
                // Only handle direct votes on active (non-locked/non-solved) items
                if (!faceVoteBtn.disabled && faceVoteBtn.dataset.action) {
                    submitVoteFromBtn(faceVoteBtn, card);
                } else if (!AUTH) {
                    // Unauthenticated: open login overlay
                    var loginOverlay = document.getElementById('bv-login-overlay');
                    if (loginOverlay) {
                        loginOverlay.classList.add('is-open');
                        document.body.style.overflow = 'hidden';
                    }
                }
                return;
            }

            // Don't toggle if the click was on any other button or link
            if (e.target.closest('button, a')) return;

            toggleCard(card);
        });

        // Keyboard: Enter/Space on the card itself
        card.addEventListener('keydown', function (e) {
            if ((e.key === 'Enter' || e.key === ' ') && e.target === card) {
                e.preventDefault();
                toggleCard(card);
            }
        });
    });

    /* ── Star vote-button keyboard activation ────────────────────────────── */
    document.querySelectorAll('.bv-rm-card__vote-btn').forEach(function (btn) {
        if (btn.tagName !== 'BUTTON') return; // skip non-interactive divs
        btn.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                e.stopPropagation();
                var card = btn.closest('.bv-rm-card');
                if (!btn.disabled && btn.dataset.action) {
                    submitVoteFromBtn(btn, card);
                } else if (card) {
                    toggleCard(card);
                }
            }
        });
    });

    /**
     * Submit a vote AJAX call from either a face star button or an action bar button.
     * This is the single shared vote submission function.
     */
    function submitVoteFromBtn(btn, card) {
        if (!AUTH) return;
        if (btn.getAttribute('aria-disabled') === 'true') return;
        if (btn.disabled) return;

        var itemId   = card.dataset.itemId;
        var itemType = card.dataset.itemType;
        var nonce    = getVoteNonce();

        if (!nonce) {
            showToast('Sikkerhedstoken mangler. Genindlæs siden.', 'error');
            return;
        }

        // Capture pre-request state for rollback
        var countEl    = card.querySelector('.bv-rm-card__vote-count');
        var budgetEl   = document.getElementById(itemType === 'bug' ? 'bv-rm-bug-budget-count' : 'bv-rm-feature-budget-count');
        var prevCount  = countEl  ? parseInt(countEl.textContent, 10)  : 0;
        var prevBudget = budgetEl ? parseInt(budgetEl.textContent, 10) : 0;

        // Disable all vote buttons for this card during request
        card.querySelectorAll('button[data-action]').forEach(function (b) { b.disabled = true; });

        var formData = new FormData();
        formData.append('item_id',    itemId);
        formData.append('vote_nonce', nonce);

        fetch('/roadmap/vote', {
            method:      'POST',
            body:        formData,
            headers:     { 'X-Requested-With': 'XMLHttpRequest' },
            credentials: 'same-origin',
        })
        .then(function (response) {
            return response.json().then(function (data) {
                return { status: response.status, data: data };
            });
        })
        .then(function (result) {
            // Re-enable vote buttons
            card.querySelectorAll('button[data-action]').forEach(function (b) { b.disabled = false; });

            if (result.status === 200 && result.data.success) {
                // Update stored nonce with fresh one-time nonce from server
                if (result.data.new_nonce) {
                    var nonceInput = document.querySelector('#bv-rm-vote-nonces [name="vote_nonce"]');
                    if (nonceInput) nonceInput.value = result.data.new_nonce;
                }

                var actualAction = result.data.action || (VOTED.indexOf(itemId) !== -1 ? 'remove' : 'add');

                // Update ALL vote count elements for this item (across all tab panels)
                document.querySelectorAll('[data-item-id="' + itemId + '"]').forEach(function (c) {
                    c.querySelectorAll('.bv-rm-card__vote-count').forEach(function (el) {
                        el.textContent = result.data.vote_count;
                    });
                });

                // Update budget counters
                var bugBudEl  = document.getElementById('bv-rm-bug-budget-count');
                var featBudEl = document.getElementById('bv-rm-feature-budget-count');
                if (bugBudEl)  bugBudEl.textContent  = result.data.bug_budget;
                if (featBudEl) featBudEl.textContent = result.data.feature_budget;
                BUG_BUD  = result.data.bug_budget;
                FEAT_BUD = result.data.feature_budget;

                // Update voted tracking and toggle button state for ALL matching cards
                document.querySelectorAll('[data-item-id="' + itemId + '"]').forEach(function (c) {
                    updateCardVoteState(c, itemId, actualAction, itemType);
                });

            } else {
                if (countEl)  countEl.textContent  = prevCount;
                if (budgetEl) budgetEl.textContent = prevBudget;
                var errMsg = (result.data && result.data.error) || 'Stemme mislykkedes. Prøv igen.';
                showToast(errMsg, 'error');
            }
        })
        .catch(function () {
            card.querySelectorAll('button[data-action]').forEach(function (b) { b.disabled = false; });
            if (countEl)  countEl.textContent  = prevCount;
            if (budgetEl) budgetEl.textContent = prevBudget;
            showToast('Netværksfejl. Kontrollér din forbindelse og prøv igen.', 'error');
        });
    }

    /* ── Action bar vote button clicks (delegates to shared submitVoteFromBtn) ── */
    document.querySelectorAll('.bv-rm-vote-btn[data-action]').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var card = btn.closest('.bv-rm-card');
            if (card) {
                submitVoteFromBtn(btn, card);
            }
        });
    });

    /**
     * After a successful vote, update the card's action bar and face button to reflect new state.
     */
    function updateCardVoteState(card, itemId, action, itemType) {
        if (!card) return;

        var addBtn    = card.querySelector('.bv-rm-vote-btn[data-action="add"]');
        var removeBtn = card.querySelector('.bv-rm-vote-btn[data-action="remove"]');
        // Star button on the card face (not inside the action bar)
        var starBtn   = card.querySelector('.bv-rm-card__vote-btn[data-action]');

        var currentBudget = (itemType === 'bug') ? BUG_BUD : FEAT_BUD;

        if (action === 'add') {
            VOTED.push(itemId);
            // Switch to "Fjern stemme" state: hide addBtn, show removeBtn
            if (addBtn) {
                addBtn.setAttribute('aria-disabled', 'true');
                addBtn.classList.add('is-voted');
                addBtn.classList.add('bv-rm-vote-btn--hidden');
            }
            if (removeBtn) {
                removeBtn.removeAttribute('aria-disabled');
                removeBtn.removeAttribute('disabled');
                removeBtn.classList.remove('bv-rm-vote-btn--hidden');
            }
            // Update face star button to reflect voted state
            if (starBtn) {
                starBtn.classList.add('is-voted');
                starBtn.setAttribute('data-action', 'remove');
                starBtn.setAttribute('aria-pressed', 'true');
                starBtn.setAttribute('aria-label', 'Fjern din stemme');
            }
        } else { // remove
            VOTED = VOTED.filter(function (id) { return id !== itemId; });
            // Switch to "Tilføj stemme" state
            if (removeBtn) {
                removeBtn.setAttribute('aria-disabled', 'true');
                removeBtn.classList.add('bv-rm-vote-btn--hidden');
            }
            if (addBtn) {
                addBtn.classList.remove('is-voted');
                addBtn.classList.remove('bv-rm-vote-btn--hidden');
                // Check budget
                if (currentBudget > 0) {
                    addBtn.removeAttribute('aria-disabled');
                    addBtn.removeAttribute('disabled');
                } else {
                    addBtn.setAttribute('aria-disabled', 'true');
                }
            }
            // Update face star button to reflect unvoted state
            if (starBtn) {
                starBtn.classList.remove('is-voted');
                starBtn.setAttribute('data-action', 'add');
                starBtn.setAttribute('aria-pressed', 'false');
                starBtn.setAttribute('aria-label', 'Stem');
                if (currentBudget <= 0) {
                    starBtn.setAttribute('aria-disabled', 'true');
                } else {
                    starBtn.removeAttribute('aria-disabled');
                }
            }
        }

        // Update all "add" buttons in the same column based on new budget
        document.querySelectorAll('[data-item-type="' + itemType + '"] .bv-rm-vote-btn[data-action="add"]').forEach(function (b) {
            var cardItemId = b.closest('[data-item-id]') ? b.closest('[data-item-id]').dataset.itemId : null;
            var alreadyVoted = VOTED.indexOf(cardItemId) !== -1;
            if (!alreadyVoted) {
                if (currentBudget <= 0) {
                    b.setAttribute('aria-disabled', 'true');
                } else {
                    b.removeAttribute('aria-disabled');
                }
            }
        });
    }

    /* ── Toast notifications ─────────────────────────────────────────────── */
    var toastTimer = null;
    function showToast(msg, type) {
        var toast = document.getElementById('bv-rm-toast');
        if (!toast) return;

        toast.className  = 'bv-rm-toast bv-rm-toast--' + (type || 'info') + ' is-visible';
        toast.textContent = msg;

        if (toastTimer) clearTimeout(toastTimer);
        toastTimer = setTimeout(function () {
            toast.classList.remove('is-visible');
        }, 5000);
    }

    /* ── Filter & "Vis løste" functionality ──────────────────────────────── */
    var filterStatus   = document.getElementById('bv-rm-filter-status');
    var filterPriority = document.getElementById('bv-rm-filter-priority');
    var filterClear    = document.getElementById('bv-rm-filter-clear');
    var showSolvedBtn  = document.getElementById('bv-rm-show-solved');
    var solvedCountEl  = document.getElementById('bv-rm-solved-count');

    var showSolved = false; // Løste items are hidden by default

    // All roadmap card elements
    function getAllCards() {
        return Array.from(document.querySelectorAll('.bv-rm-card[data-item-id]'));
    }

    // Update tab count badges based on visible (non-hidden) cards in each section
    function updateTabCounts() {
        var activeStatusFilter   = filterStatus   ? filterStatus.value   : '';
        var activePriorityFilter = filterPriority ? filterPriority.value : '';

        // Deduplicate counts by item-id (items appear in both "Alle" and type panels)
        var seenIds         = {};
        var totalVisible    = 0;
        var bugsVisible     = 0;
        var featuresVisible = 0;

        getAllCards().forEach(function (card) {
            var itemId   = card.dataset.itemId   || '';
            var type     = card.dataset.itemType || '';
            var status   = card.dataset.itemStatus   || '';
            var priority = card.dataset.itemPriority || '';
            var isSolved = (status === 'loest');

            var matchesStatus   = !activeStatusFilter   || status === activeStatusFilter;
            var matchesPriority = !activePriorityFilter || priority === activePriorityFilter;
            var matchesSolved   = showSolved || !isSolved;

            var visible = matchesStatus && matchesPriority && matchesSolved;

            // Show/hide this card element (applies to all copies across all panels)
            card.style.display = visible ? '' : 'none';

            // Count each unique item only once (deduplicate across Alle + type panels)
            if (visible && itemId && !seenIds[itemId]) {
                seenIds[itemId] = true;
                totalVisible++;
                if (type === 'bug') bugsVisible++;
                else                featuresVisible++;
            }
        });

        // Update tab count badges
        var allCountEl  = document.querySelector('#bv-rm-tab-alle .bv-rm-tab__count');
        var bugCountEl  = document.querySelector('#bv-rm-tab-fejl .bv-rm-tab__count');
        var featCountEl = document.querySelector('#bv-rm-tab-feature-forslag .bv-rm-tab__count');
        if (allCountEl)  allCountEl.textContent  = totalVisible;
        if (bugCountEl)  bugCountEl.textContent  = bugsVisible;
        if (featCountEl) featCountEl.textContent = featuresVisible;

        // Show/hide empty states inside tab panels
        updateEmptyStates(bugsVisible, featuresVisible, totalVisible);

        // Show/hide clear button
        var hasFilter = activeStatusFilter || activePriorityFilter;
        if (filterClear) {
            if (hasFilter) {
                filterClear.removeAttribute('hidden');
            } else {
                filterClear.setAttribute('hidden', '');
            }
        }
    }

    function updateEmptyStates(bugsVisible, featuresVisible, totalVisible) {
        // Alle panel
        var allePanel = document.getElementById('bv-rm-tabpanel-alle');
        if (allePanel) {
            var emptyAlle  = allePanel.querySelector('.bv-rm-empty-state');
            var cardsAlle  = allePanel.querySelector('.bv-rm-cards');
            var filterMsgAlle = allePanel.querySelector('.bv-rm-filter-empty');
            var hasAnyCards = cardsAlle && cardsAlle.querySelectorAll('.bv-rm-card[data-item-id]').length > 0;
            if (hasAnyCards) {
                if (totalVisible === 0) {
                    if (cardsAlle) cardsAlle.style.display = 'none';
                    if (!filterMsgAlle) {
                        filterMsgAlle = createFilterEmptyMsg();
                        allePanel.appendChild(filterMsgAlle);
                    } else { filterMsgAlle.style.display = ''; }
                } else {
                    if (cardsAlle) cardsAlle.style.display = '';
                    if (filterMsgAlle) filterMsgAlle.style.display = 'none';
                }
            }
        }

        // Fejl panel
        var fejlPanel = document.getElementById('bv-rm-tabpanel-fejl');
        if (fejlPanel) {
            var emptyFejl  = fejlPanel.querySelector('.bv-rm-empty-state');
            var cardsFejl  = fejlPanel.querySelector('.bv-rm-cards');
            var filterMsgFejl = fejlPanel.querySelector('.bv-rm-filter-empty');
            var hasAnyBugCards = cardsFejl && cardsFejl.querySelectorAll('.bv-rm-card[data-item-id]').length > 0;
            if (hasAnyBugCards) {
                if (bugsVisible === 0) {
                    if (cardsFejl) cardsFejl.style.display = 'none';
                    if (!filterMsgFejl) {
                        filterMsgFejl = createFilterEmptyMsg();
                        fejlPanel.appendChild(filterMsgFejl);
                    } else { filterMsgFejl.style.display = ''; }
                } else {
                    if (cardsFejl) cardsFejl.style.display = '';
                    if (filterMsgFejl) filterMsgFejl.style.display = 'none';
                }
            }
        }

        // Feature panel
        var featPanel = document.getElementById('bv-rm-tabpanel-feature-forslag');
        if (featPanel) {
            var emptyFeat  = featPanel.querySelector('.bv-rm-empty-state');
            var cardsFeat  = featPanel.querySelector('.bv-rm-cards');
            var filterMsgFeat = featPanel.querySelector('.bv-rm-filter-empty');
            var hasAnyFeatCards = cardsFeat && cardsFeat.querySelectorAll('.bv-rm-card[data-item-id]').length > 0;
            if (hasAnyFeatCards) {
                if (featuresVisible === 0) {
                    if (cardsFeat) cardsFeat.style.display = 'none';
                    if (!filterMsgFeat) {
                        filterMsgFeat = createFilterEmptyMsg();
                        featPanel.appendChild(filterMsgFeat);
                    } else { filterMsgFeat.style.display = ''; }
                } else {
                    if (cardsFeat) cardsFeat.style.display = '';
                    if (filterMsgFeat) filterMsgFeat.style.display = 'none';
                }
            }
        }
    }

    function createFilterEmptyMsg() {
        var el = document.createElement('div');
        el.className = 'bv-rm-empty-state bv-rm-filter-empty';
        el.innerHTML =
            '<span class="material-symbols-outlined bv-rm-empty-state__icon" aria-hidden="true">filter_alt_off</span>' +
            '<h2 class="bv-rm-empty-state__title">Ingen emner matcher filteret</h2>' +
            '<p class="bv-rm-empty-state__text">Prøv at vælge et andet filter eller nulstil for at se alle emner.</p>';
        return el;
    }

    // Apply initial state: hide solved cards
    (function initSolvedState() {
        var solvedCards = getAllCards().filter(function (c) {
            return (c.dataset.itemStatus || '') === 'loest';
        });

        // Count unique solved items (deduplicate across Alle + type panels)
        var seenSolvedIds = {};
        var solvedCount = 0;
        solvedCards.forEach(function (c) {
            var id = c.dataset.itemId || '';
            if (id && !seenSolvedIds[id]) {
                seenSolvedIds[id] = true;
                solvedCount++;
            }
        });

        // Hide all solved card elements initially
        solvedCards.forEach(function (c) { c.style.display = 'none'; });

        // Update toggle button label
        if (showSolvedBtn && solvedCount > 0) {
            if (solvedCountEl) solvedCountEl.textContent = '(' + solvedCount + ')';
        } else if (showSolvedBtn) {
            // No solved items — hide toggle
            showSolvedBtn.style.display = 'none';
        }

        // Update initial tab counts (without solved)
        updateTabCounts();
    }());

    // "Vis løste" toggle click
    if (showSolvedBtn) {
        showSolvedBtn.addEventListener('click', function () {
            showSolved = !showSolved;
            showSolvedBtn.setAttribute('aria-pressed', showSolved ? 'true' : 'false');
            showSolvedBtn.classList.toggle('is-active', showSolved);
            updateTabCounts();
        });
    }

    // Filter change handlers
    if (filterStatus) {
        filterStatus.addEventListener('change', function () { updateTabCounts(); });
    }
    if (filterPriority) {
        filterPriority.addEventListener('change', function () { updateTabCounts(); });
    }

    // Clear filters
    if (filterClear) {
        filterClear.addEventListener('click', function () {
            if (filterStatus)   filterStatus.value   = '';
            if (filterPriority) filterPriority.value = '';
            updateTabCounts();
        });
    }

    /* ── Copy-link button ────────────────────────────────────────────────── */
    document.querySelectorAll('.bv-rm-card__copy-btn[data-anchor]').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var anchor    = btn.dataset.anchor;
            var fullUrl   = window.location.origin + '/roadmap#' + anchor;
            var labelEl   = btn.querySelector('.bv-rm-card__copy-btn-label');
            var iconEl    = btn.querySelector('.material-symbols-outlined');
            var origLabel = labelEl ? labelEl.textContent : 'Kopier link';
            var origIcon  = iconEl  ? iconEl.textContent  : 'link';

            function showConfirm() {
                btn.classList.add('bv-rm-card__copy-btn--copied');
                if (labelEl) labelEl.textContent = 'Kopieret!';
                if (iconEl)  iconEl.textContent  = 'check';
                setTimeout(function () {
                    btn.classList.remove('bv-rm-card__copy-btn--copied');
                    if (labelEl) labelEl.textContent = origLabel;
                    if (iconEl)  iconEl.textContent  = origIcon;
                }, 2000);
            }

            function showError() {
                // Fallback: select a temporary input field with the URL
                var inp = document.createElement('input');
                inp.value = fullUrl;
                inp.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0;';
                document.body.appendChild(inp);
                inp.select();
                inp.setSelectionRange(0, 99999);
                try {
                    document.execCommand('copy');
                    showConfirm();
                } catch (ex) {
                    if (labelEl) labelEl.textContent = 'Kopier fejlede';
                    setTimeout(function () { if (labelEl) labelEl.textContent = origLabel; }, 3000);
                }
                document.body.removeChild(inp);
            }

            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(fullUrl).then(showConfirm, showError);
            } else {
                showError();
            }
        });
    });

    /* ── Anchor deep-link: scroll to card on page load if URL has fragment ── */
    (function () {
        var hash = window.location.hash;
        if (!hash) return;
        // Normalise to lowercase so #B004 and #b004 both resolve to id="b004"
        var id = hash.slice(1).toLowerCase();

        // Update URL to canonical lowercase form if needed
        if (hash.slice(1) !== id) {
            history.replaceState(null, '', '/roadmap#' + id);
        }

        // Find any card with this anchor id (using data-anchor-id, available on all panels)
        // This lets us read item metadata without relying on the id attribute
        var anyCard = document.querySelector('[data-anchor-id="' + id + '"]');
        if (!anyCard) return;

        // Make sure solved card is visible before switching tabs
        if ((anyCard.dataset.itemStatus || '') === 'loest') {
            showSolved = true;
            if (showSolvedBtn) {
                showSolvedBtn.setAttribute('aria-pressed', 'true');
                showSolvedBtn.classList.add('is-active');
            }
            updateTabCounts();
        }

        // Switch to the correct type-specific tab so the canonical-id element becomes visible.
        // Cards in the type panels carry id="{{ anchor_id }}"; cards in the Alle panel do NOT,
        // so after the tab switch document.getElementById(id) will find the now-visible card.
        var itemType = anyCard.dataset.itemType || '';
        var targetTabId = itemType === 'bug'
            ? 'bv-rm-tab-fejl'
            : (itemType === 'feature' ? 'bv-rm-tab-feature-forslag' : null);

        if (targetTabId) {
            var targetTab = document.getElementById(targetTabId);
            if (targetTab) targetTab.click();
        }

        // After the tab switch (and the DOM is updated), locate the now-visible canonical element
        setTimeout(function () {
            var target = document.getElementById(id);
            if (!target) return;
            target.scrollIntoView({ behavior: 'smooth', block: 'center' });
            target.classList.add('bv-rm-card--highlighted');
            setTimeout(function () { target.classList.remove('bv-rm-card--highlighted'); }, 2000);
        }, 100);
    }());

}());
</script>
{% endblock %}
