# Credentials for deploy/deploy.sh.
#
# The hackersbychoice.dk one.com account hosts staging (apex), test
# (test.hackersbychoice.dk → /test folder), and dev (dev.hackersbychoice.dk
# → /dev folder). These three tiers share the same SFTP credentials.
DEPLOY_HOST=ssh.hackersbychoice.dk
DEPLOY_USER=hackersbychoice.dk
DEPLOY_PORT=22
DEPLOY_PATH=/customers/4/e/5/hackersbychoice.dk/httpd.www
DEPLOY_PASS=your-sftp-password-here

# Production (www.byvaerkstederne.dk) lives on a SEPARATE hosting account.
# Until those credentials are populated, `./deploy.sh prod` will fail loud
# with a missing-variable error rather than silently falling back to the
# hackersbychoice.dk account and overwriting staging.
#
# Hosting provider for byvaerkstederne.dk has not yet been verified — fill
# these in once it has.
#DEPLOY_PROD_HOST=
#DEPLOY_PROD_USER=
#DEPLOY_PROD_PORT=22
#DEPLOY_PROD_PATH=
#DEPLOY_PROD_PASS=

# ─── Backup managed-storage credentials ─────────────────────────────
#
# `deploy/backup.sh` uploads encrypted archives to managed storage.
# Two backends are supported; pick ONE:
#
# 1. S3 / S3-compatible (AWS, Backblaze B2, Wasabi, MinIO, etc.).
#    Recommended. Set BACKUP_S3_BUCKET; the rest are optional.
#
#BACKUP_S3_BUCKET=byvaerkstederne-backups
#BACKUP_S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
#BACKUP_S3_ACCESS_KEY_ID=replace-with-real-access-key-id
#BACKUP_S3_SECRET_ACCESS_KEY=replace-with-real-secret-access-key
#
# 2. Local-disk store (a directory acting as managed storage). Useful
#    for testing and the GAN evaluator. Mutually exclusive with the S3
#    backend — if BACKUP_LOCAL_STORE_DIR is set, it wins.
#
#BACKUP_LOCAL_STORE_DIR=/path/to/backup/store
#
# Restore tooling (`deploy/restore.sh`) reuses the same variables.
# AGE_IDENTITY_FILE points to the operator's age private key (kept in
# a password manager / hardware key — NEVER committed):
#
#AGE_IDENTITY_FILE=/Users/you/.config/age/byvaerksted.key
