# Credentials for deploy/deploy.sh.
#
# The hackersbychoice.dk one.com account hosts staging (apex), test
# (test.hackersbychoice.dk → /test folder), and dev (dev.hackersbychoice.dk
# → /dev folder). These three tiers share the same SFTP credentials.
DEPLOY_HOST=ssh.hackersbychoice.dk
DEPLOY_USER=hackersbychoice.dk
DEPLOY_PORT=22
DEPLOY_PATH=/customers/4/e/5/hackersbychoice.dk/httpd.www
DEPLOY_PASS=your-sftp-password-here

# Production (www.byvaerkstederne.dk) lives on a SEPARATE hosting account.
# Until those credentials are populated, `./deploy.sh prod` will fail loud
# with a missing-variable error rather than silently falling back to the
# hackersbychoice.dk account and overwriting staging.
#
# Hosting provider for byvaerkstederne.dk has not yet been verified — fill
# these in once it has.
#DEPLOY_PROD_HOST=
#DEPLOY_PROD_USER=
#DEPLOY_PROD_PORT=22
#DEPLOY_PROD_PATH=
#DEPLOY_PROD_PASS=
